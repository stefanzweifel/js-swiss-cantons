{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["es2023"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "types": ["node"],
        "isolatedModules": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src", "test", "tsdown.config.ts"]
}
